{
  "name": "backend-api",
  "version": "1.0.0",
  "description": "Backend API with Express and Sequelize",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --inspect=0.0.0.0:9229 --ext ts,js server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "test": "jest",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-rate-limit": "^6.7.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.1",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.7",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "jest": "^29.6.1",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "sequelize-cli": "^6.6.1",
    "supertest": "^6.3.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  },
  "keywords": [
    "express",
    "sequelize",
    "postgresql",
    "api"
  ],
  "author": "Tu Nombre",
  "license": "MIT"
}
