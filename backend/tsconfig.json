{
  "compilerOptions": {
    "target": "ES2022" /* Versión de JS de salida */,
    "module": "CommonJS" /* 🔴 CLAVE: Fuerza a traducir los import/export a require */,
    "moduleResolution": "node" /* Cómo busca los archivos Node */,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true /* Permite compatibilidad total entre require e import */,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true /* Respeta mayúsculas y minúsculas */,
    "strict": true /* Habilita el tipado estricto de TS */,
    "skipLibCheck": true /* Omite la comprobación de tipos de las librerías */,
    "outDir": "./dist",
    "rootDir": ".",
    "allowJs": true
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "dist"]
}